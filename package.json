  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "html-to-image": "^1.11.13",
